# OS
.DS_Store

# pmpt (https://pmptwiki.com) — keep dev journal docs in git, but the
# .pmpt/.history snapshot store is large append-only binary-ish data
# (4 file copies per snapshot × N versions). Treat like a local cache;
# pmpt_save / pmpt_history work fine without it being in git, and
# `pmpt_publish` reads docs/, not history/.
.pmpt/.history/

